---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import TechStack from "../components/TechStack.astro";
import Services from "../components/Services.astro";
import WhyUs from "../components/WhyUs.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="GitByte DOO — Backend Engineering Studio | Symfony, Laravel, PHP"
  description="Engineering studio specialising in backend systems for SaaS companies. Symfony, Laravel, PHP, and API architecture."
>
  <Navbar />

  <Hero />

  <!-- Work -->
  <section id="work" class="section-container section-padding relative py-24 sm:py-32 lg:py-40 bg-gradient-section" data-reveal>
    <div class="mx-auto max-w-6xl">
      <div class="section-label">
        <span class="section-label-line" aria-hidden="true" />
        <span class="section-label-text">Selected Work</span>
      </div>
      <h2 class="heading-lg text-balance text-zinc-100">
        Some things I've built.
      </h2>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-reveal-stagger>
        <article class="group glass cursor-pointer rounded-2xl p-6 hover:border-cyan-400/20 hover:bg-zinc-900/80 hover:shadow-[0_0_32px_rgba(34,211,238,0.06)] active:brightness-90 sm:p-7" data-index="0" data-tilt data-reveal>
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-400/10">
            <svg class="h-6 w-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
            </svg>
          </div>
          <h3 class="heading text-zinc-100">SaaS Subscription Platform</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            Recurring billing for multi-tenant SaaS platforms
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="rounded-md border border-zinc-800/60 bg-zinc-900/80 px-2 py-0.5 text-xs font-medium text-zinc-500">Symfony</span>
            <span class="rounded-md border border-zinc-800/60 bg-zinc-900/80 px-2 py-0.5 text-xs font-medium text-zinc-500">React</span>
            <span class="rounded-md border border-zinc-800/60 bg-zinc-900/80 px-2 py-0.5 text-xs font-medium text-zinc-500">Stripe</span>
            <span class="rounded-md border border-zinc-800/60 bg-zinc-900/80 px-2 py-0.5 text-xs font-medium text-zinc-500">MySQL</span>
          </div>
          <span class="mt-4 inline-flex items-center gap-1 text-xs text-cyan-400/60 transition-colors group-hover:text-cyan-400">
            View details <span aria-hidden="true">&rarr;</span>
          </span>
        </article>

        <article class="group glass cursor-pointer rounded-2xl p-6 hover:border-cyan-400/20 hover:bg-zinc-900/80 hover:shadow-[0_0_32px_rgba(34,211,238,0.06)] active:brightness-90 sm:p-7" data-index="1" data-tilt data-reveal>
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-400/10">
            <svg class="h-6 w-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
            </svg>
          </div>
          <h3 class="heading text-zinc-100">Document Management CMS</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            Versioned document engine with server-side PDF rendering
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="rounded-md border border-zinc-800/60 bg-zinc-900/80 px-2 py-0.5 text-xs font-medium text-zinc-500">Laravel</span>
            <span class="rounded-md border border-zinc-800/60 bg-zinc-900/80 px-2 py-0.5 text-xs font-medium text-zinc-500">MySQL</span>
            <span class="rounded-md border border-zinc-800/60 bg-zinc-900/80 px-2 py-0.5 text-xs font-medium text-zinc-500">PHP</span>
          </div>
          <span class="mt-4 inline-flex items-center gap-1 text-xs text-cyan-400/60 transition-colors group-hover:text-cyan-400">
            View details <span aria-hidden="true">&rarr;</span>
          </span>
        </article>

        <article class="group glass cursor-pointer rounded-2xl p-6 hover:border-cyan-400/20 hover:bg-zinc-900/80 hover:shadow-[0_0_32px_rgba(34,211,238,0.06)] active:brightness-90 sm:col-span-2 sm:p-7 lg:col-span-1" data-index="2" data-tilt data-reveal>
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-400/10">
            <svg class="h-6 w-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
            </svg>
          </div>
          <h3 class="heading text-zinc-100">Inventory Management API</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            Multi-warehouse inventory API with supplier coordination
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="rounded-md border border-zinc-800/60 bg-zinc-900/80 px-2 py-0.5 text-xs font-medium text-zinc-500">Symfony</span>
            <span class="rounded-md border border-zinc-800/60 bg-zinc-900/80 px-2 py-0.5 text-xs font-medium text-zinc-500">MySQL</span>
          </div>
          <span class="mt-4 inline-flex items-center gap-1 text-xs text-cyan-400/60 transition-colors group-hover:text-cyan-400">
            View details <span aria-hidden="true">&rarr;</span>
          </span>
        </article>
      </div>
    </div>
  </section>

  <!-- Work modal -->
  <div
    id="project-modal"
    class="fixed inset-0 z-[100] flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modal-title"
  >
    <div class="absolute inset-0 bg-zinc-950/80 backdrop-blur-sm" data-modal-close></div>
    <div class="relative max-h-[85vh] w-full max-w-2xl overflow-y-auto rounded-2xl border border-zinc-800 bg-zinc-900 p-8 shadow-2xl">
      <button
        class="absolute right-4 top-4 flex h-8 w-8 items-center justify-center rounded-lg text-zinc-500 hover:text-zinc-300"
        data-modal-close
        aria-label="Close"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
      <div id="modal-body"></div>
    </div>
  </div>

  <Services />

  <WhyUs />

  <TechStack />

  <!-- About -->
  <section id="about" class="section-container section-padding relative py-24 sm:py-32 lg:py-40" data-reveal>
    <div class="mx-auto max-w-6xl">
      <div class="section-label">
        <span class="section-label-line" aria-hidden="true" />
        <span class="section-label-text">About</span>
      </div>

      <div class="max-w-3xl">
        <h2 class="heading-lg text-balance text-zinc-100">
          Engineering studio.
          <br />
          <span class="gradient-text">Backend DNA.</span>
        </h2>
        <p class="mt-6 text-base leading-relaxed text-zinc-400">
          I work directly with technical founders and engineering teams. No account managers — just me.
        </p>
        <p class="mt-4 text-base leading-relaxed text-zinc-400">
          <strong class="text-zinc-300">Good fit:</strong> billing systems, APIs, data pipelines — the backend infrastructure that makes SaaS work.
          <br />
          <strong class="text-zinc-300">Not a fit:</strong> landing pages, mobile apps, brand design. I stay in my lane.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="https://github.com/Vimpil"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl border border-zinc-800 bg-zinc-900/50 px-4 py-2.5 text-sm font-medium text-zinc-300 transition-colors hover:border-zinc-700 hover:bg-zinc-900"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
            GitHub &rarr;
          </a>
          <a
            href="https://www.linkedin.com/in/lifetrue"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl border border-zinc-800 bg-zinc-900/50 px-4 py-2.5 text-sm font-medium text-zinc-300 transition-colors hover:border-zinc-700 hover:bg-zinc-900"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn &rarr;
          </a>
          <a
            href="https://www.upwork.com/agencies/1942512521968274328/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl border border-zinc-800 bg-zinc-900/50 px-4 py-2.5 text-sm font-medium text-zinc-300 transition-colors hover:border-zinc-700 hover:bg-zinc-900"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 0 0 .75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 0 0-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0 1 12 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 0 1-.673-.38m0 0A2.18 2.18 0 0 1 3 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 0 1 3.413-.387m7.5 0V5.25A2.25 2.25 0 0 0 13.5 3h-3a2.25 2.25 0 0 0-2.25 2.25v.894m7.5 0a48.667 48.667 0 0 0-7.5 0M12 12.75h.008v.008H12v-.008Z" />
            </svg>
            View on Upwork &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <CTA />
  <Footer />
</Layout>

<script>
  (() => {
    const modal = document.getElementById("project-modal");
    const body = document.getElementById("modal-body");
    const triggers = document.querySelectorAll("[data-index]");
    const closes = modal.querySelectorAll("[data-modal-close]");

    const projects = [
      {
        name: "SaaS Subscription Platform",
        summary: "I built a recurring billing engine with metered pricing, dunning management, and multi-tenant account isolation. Stripe webhooks reconciled via idempotent consumers — no duplicate charges, no missed events.",
        highlights: [
          "Stripe webhook consumers that guarantee exactly-once processing",
          "Multi-tenant data isolation at the database level",
          "Automated dunning escalation with configurable timing",
          "Metered usage tracking with per-customer invoice aggregation",
        ],
        constraints: "High-volume webhook reconciliation without duplicates. Tenant data isolation in a shared database. Dunning timing across multiple time zones and billing cycles.",
        tags: ["Symfony", "React", "Stripe", "MySQL"],
        result: "Production billing engine processing recurring revenue with zero reconciliation errors since deployment.",
      },
      {
        name: "Document Management CMS",
        summary: "A versioned document engine with server-side PDF rendering and fine-grained role-based access. Laravel queue workers handle async document generation, and every mutation gets logged in an audit trail.",
        highlights: [
          "Async queue workers prevent PDF generation from blocking user requests",
          "Fine-grained role-based access at document and folder level",
          "Full mutation audit trail for compliance requirements",
          "Server-side template rendering with custom CSS theming",
        ],
        constraints: "Concurrent document generation at scale without timeout. PDF rendering must not block user requests. Complete audit trail for every document mutation.",
        tags: ["Laravel", "MySQL", "PHP"],
        result: "Production CMS handling thousands of generated documents with full audit trail compliance.",
      },
      {
        name: "Inventory Management API",
        summary: "A RESTful API layer connecting multi-warehouse inventory, supplier coordination, and order orchestration. Idempotent webhooks bridge modern APIs with legacy warehouse systems — no downtime, no data loss.",
        highlights: [
          "Idempotent webhook contracts guarantee delivery exactly once",
          "ETL pipeline bridges modern API with legacy warehouse systems",
          "Real-time inventory sync across 5+ warehouse locations",
          "Supplier coordination workflow with automated reorder triggers",
        ],
        constraints: "Bidirectional sync with legacy systems that have no API. Zero downtime during integration. Inventory consistency across geographically distributed warehouses.",
        tags: ["Symfony", "MySQL"],
        result: "Connected 5+ warehouses with real-time inventory sync, enabling centralized order orchestration.",
      },
    ];

    function open(index) {
      const p = projects[index];
      body.innerHTML =
        '<h3 class="heading text-zinc-100" id="modal-title">' +
        p.name +
        "</h3>" +
        '<p class="mt-4 text-sm leading-relaxed text-zinc-400">' +
        p.summary +
        "</p>" +
        '<h4 class="mt-6 text-sm font-semibold text-zinc-300">Architecture highlights</h4>' +
        '<ul class="mt-3 space-y-2">' +
        p.highlights
          .map(
            (h) =>
              '<li class="flex gap-3 text-sm text-zinc-400"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-cyan-400/60"></span>' +
              h +
              "</li>"
          )
          .join("") +
        "</ul>" +
        '<h4 class="mt-6 text-sm font-semibold text-zinc-300">Key constraints</h4>' +
        '<p class="mt-2 text-sm leading-relaxed text-zinc-400">' +
        p.constraints +
        "</p>" +
        '<div class="mt-6 flex flex-wrap gap-2">' +
        p.tags
          .map(
            (t) =>
              '<span class="rounded-md border border-zinc-800/60 bg-zinc-900/80 px-2 py-0.5 text-xs font-medium text-zinc-500">' +
              t +
              "</span>"
          )
          .join("") +
        "</div>" +
        '<p class="mt-6 rounded-xl border border-cyan-400/20 bg-cyan-400/5 px-4 py-3 text-sm text-cyan-300">' +
        p.result +
        "</p>";
      modal.classList.remove("opacity-0", "pointer-events-none");
      document.body.style.overflow = "hidden";
    }

    function close() {
      modal.classList.add("opacity-0", "pointer-events-none");
      document.body.style.overflow = "";
    }

    triggers.forEach((el) => {
      el.addEventListener("click", () => open(parseInt(el.dataset.index)));
    });
    closes.forEach((el) => el.addEventListener("click", close));
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });
  })();
</script>
