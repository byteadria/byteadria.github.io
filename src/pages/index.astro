---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import TechStack from "../components/TechStack.astro";
import Services from "../components/Services.astro";
import WhyUs from "../components/WhyUs.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Forge Systems | Engineering-Grade Teams — Scalable Systems & Products"
  description="High-end software development agency specializing in scalable backend architecture with Symfony/PHP, modern React frontends, expert system design, and bulletproof integrations."
>
  <Navbar />

  <Hero />

  <!-- Work -->
  <section id="work" class="section-container section-padding relative py-24 sm:py-32 lg:py-40" data-reveal>
    <div class="mx-auto max-w-6xl">
      <div class="mb-4 flex items-center gap-3">
        <span class="h-px w-8 bg-cyan-400/60" aria-hidden="true" />
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-400">Selected Work</span>
      </div>
      <h2 class="text-balance text-3xl font-bold tracking-tight text-zinc-100 sm:text-4xl lg:text-5xl">
        Products we've shaped.
      </h2>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-reveal-stagger>
        <article class="group glass rounded-2xl p-6 transition-all duration-300 hover:border-cyan-400/20 hover:bg-zinc-900/80 hover:shadow-[0_0_32px_rgba(34,211,238,0.06)] sm:p-7" data-tilt data-reveal>
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-400/10">
            <svg class="h-6 w-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-zinc-100">Fintech Dashboard</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            Real-time analytics platform handling 2M+ transactions daily.
            React + Rust backend, sub-10ms p99 latency.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="rounded-md border border-zinc-800/60 bg-zinc-900/80 px-2 py-0.5 text-xs font-medium text-zinc-500">React</span>
            <span class="rounded-md border border-zinc-800/60 bg-zinc-900/80 px-2 py-0.5 text-xs font-medium text-zinc-500">Rust</span>
            <span class="rounded-md border border-zinc-800/60 bg-zinc-900/80 px-2 py-0.5 text-xs font-medium text-zinc-500">Postgres</span>
          </div>
        </article>

        <article class="group glass rounded-2xl p-6 transition-all duration-300 hover:border-cyan-400/20 hover:bg-zinc-900/80 hover:shadow-[0_0_32px_rgba(34,211,238,0.06)] sm:p-7" data-tilt data-reveal>
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-400/10">
            <svg class="h-6 w-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-zinc-100">AI SaaS Platform</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            API-first ML inference platform serving 500K+ requests/hour.
            Go + Python, distributed GPU scheduling.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="rounded-md border border-zinc-800/60 bg-zinc-900/80 px-2 py-0.5 text-xs font-medium text-zinc-500">Go</span>
            <span class="rounded-md border border-zinc-800/60 bg-zinc-900/80 px-2 py-0.5 text-xs font-medium text-zinc-500">Python</span>
            <span class="rounded-md border border-zinc-800/60 bg-zinc-900/80 px-2 py-0.5 text-xs font-medium text-zinc-500">K8s</span>
          </div>
        </article>

        <article class="group glass rounded-2xl p-6 transition-all duration-300 hover:border-cyan-400/20 hover:bg-zinc-900/80 hover:shadow-[0_0_32px_rgba(34,211,238,0.06)] sm:col-span-2 sm:p-7 lg:col-span-1" data-tilt data-reveal>
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-400/10">
            <svg class="h-6 w-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-zinc-100">E-Commerce Engine</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            Headless commerce platform for a Fortune 500 retailer. 99.99% uptime,
            sub-200ms global checkout.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="rounded-md border border-zinc-800/60 bg-zinc-900/80 px-2 py-0.5 text-xs font-medium text-zinc-500">Next.js</span>
            <span class="rounded-md border border-zinc-800/60 bg-zinc-900/80 px-2 py-0.5 text-xs font-medium text-zinc-500">Node</span>
            <span class="rounded-md border border-zinc-800/60 bg-zinc-900/80 px-2 py-0.5 text-xs font-medium text-zinc-500">Redis</span>
          </div>
        </article>
      </div>
    </div>
  </section>

  <TechStack />
  <Services />
  <WhyUs />

  <!-- About -->
  <section id="about" class="section-container section-padding relative py-24 sm:py-32 lg:py-40" data-reveal>
    <div class="mx-auto max-w-6xl">
      <div class="mb-4 flex items-center gap-3">
        <span class="h-px w-8 bg-cyan-400/60" aria-hidden="true" />
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-400">About us</span>
      </div>

      <div class="grid items-center gap-16 lg:grid-cols-2">
        <div>
          <h2 class="text-balance text-3xl font-bold tracking-tight text-zinc-100 sm:text-4xl lg:text-5xl">
            Built by engineers,
            <br />
            <span class="gradient-text">for product teams.</span>
          </h2>
          <p class="mt-6 text-base leading-relaxed text-zinc-400">
            We're a tight-knit team of senior engineers who've shipped at
            companies like Stripe, Vercel, and Linear. We've scaled databases
            past 10TB, designed APIs serving millions, and rebuilt frontends
            that cut load times by 80%.
          </p>
          <p class="mt-4 text-base leading-relaxed text-zinc-400">
            We don't just write code — we partner with you to make the right
            technical decisions, move fast without breaking things, and deliver
            products that stand the test of production.
          </p>
          <div class="mt-8 grid grid-cols-3 gap-8 border-y border-zinc-800/50 py-8">
            <div>
              <span class="text-2xl font-bold text-zinc-100">15+</span>
              <p class="mt-1 text-xs text-zinc-500">Years combined experience</p>
            </div>
            <div>
              <span class="text-2xl font-bold text-zinc-100">40+</span>
              <p class="mt-1 text-xs text-zinc-500">Projects delivered</p>
            </div>
            <div>
              <span class="text-2xl font-bold text-zinc-100">100%</span>
              <p class="mt-1 text-xs text-zinc-500">Client satisfaction</p>
            </div>
          </div>
        </div>

        <div class="glass gradient-border rounded-2xl p-8">
          <blockquote class="text-base leading-relaxed text-zinc-300">
            "Forge Systems completely transformed our infrastructure. They
            redesigned our monolithic backend into a clean event-driven
            architecture that handles 10x the traffic with half the cost.
            Their attention to detail is unmatched."
          </blockquote>
          <div class="mt-6 flex items-center gap-4">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-zinc-800 text-sm font-semibold text-zinc-400" aria-hidden="true">
              SK
            </div>
            <div>
              <p class="text-sm font-semibold text-zinc-200">Sarah Kim</p>
              <p class="text-xs text-zinc-500">CTO, Pulse Analytics</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA />
  <Footer />
</Layout>
