---
export interface Props {
  upworkHref?: string;
  workAnchor?: string;
  brandName?: string;
}

const {
  upworkHref = "https://upwork.com",
  workAnchor = "#work",
  brandName = "Forge Systems",
} = Astro.props;
---

<section
  class="relative flex min-h-svh items-center overflow-hidden bg-zinc-950"
  aria-label="Hero"
>
  <!-- Animated background -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-grid" />
    <div class="absolute inset-0 bg-noise" />
    <div
      class="animate-drift absolute -left-[25%] -top-[25%] h-[150%] w-[150%] opacity-25"
      style="
        background: radial-gradient(
          ellipse 60% 50% at 30% 40%,
          rgba(34, 211, 238, 0.15),
          transparent 70%
        );
      "
    />
    <div
      class="animate-drift-reverse absolute -bottom-[25%] -right-[25%] h-[150%] w-[150%] opacity-20"
      style="
        background: radial-gradient(
          ellipse 50% 60% at 70% 60%,
          rgba(34, 211, 238, 0.1),
          transparent 70%
        );
      "
    />
    <div
      class="absolute left-1/2 top-1/2 h-[50vh] w-[50vh] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-[0.08] blur-3xl"
      style="background: radial-gradient(circle, #22d3ee, transparent 70%)"
    />
  </div>

  <div
    class="mx-auto flex w-full max-w-7xl flex-col items-center px-4 pt-28 pb-16 text-center sm:px-6 sm:pt-32 lg:px-8"
  >
    <!-- Availability chip -->
    <div
      class="animate-fade-in-down mb-6 inline-flex items-center gap-2 rounded-full border border-zinc-800 bg-zinc-900/50 px-4 py-1.5 text-xs font-medium text-zinc-400 sm:mb-8"
    >
      <span class="relative flex h-1.5 w-1.5">
        <span
          class="absolute inline-flex h-full w-full animate-ping rounded-full bg-cyan-400/60"
        />
        <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-cyan-400" />
      </span>
      Available for new projects
    </div>

    <p
      class="animate-fade-in-down mb-4 text-sm font-semibold uppercase tracking-[0.25em] text-zinc-500 sm:mb-6"
      style="animation-delay: 0.05s"
    >
      {brandName}
    </p>

    <h1
      class="animate-fade-in text-balance text-5xl font-extrabold leading-[1.05] tracking-tight text-zinc-100 sm:text-7xl lg:text-8xl xl:text-9xl"
      style="animation-delay: 0.1s"
    >
      Engineering-grade&nbsp;teams
      <br class="hidden sm:block" />
      building
      <span class="gradient-text"> scalable, </span>
      <br class="block sm:hidden" />
      high-performance
      <br class="hidden sm:block" />
      systems
      <br class="block sm:hidden" />
      for ambitious&nbsp;products.
    </h1>

    <p
      class="animate-fade-in-up mx-auto mt-6 max-w-3xl text-balance text-base leading-relaxed text-zinc-400 sm:mt-8 sm:text-lg lg:text-xl"
      style="animation-delay: 0.2s"
      role="list"
    >
      <span class="inline-flex flex-wrap items-center justify-center gap-x-2 gap-y-1.5">
        <span class="inline-flex items-center gap-1.5" role="listitem">
          <svg class="h-3.5 w-3.5 shrink-0 text-cyan-400/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
          Backend with Symfony/PHP
        </span>
        <span class="hidden sm:inline text-zinc-600" aria-hidden="true">•</span>
        <span class="inline-flex items-center gap-1.5" role="listitem">
          <svg class="h-3.5 w-3.5 shrink-0 text-cyan-400/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
          Modern React frontends
        </span>
        <span class="hidden sm:inline text-zinc-600" aria-hidden="true">•</span>
        <span class="inline-flex items-center gap-1.5" role="listitem">
          <svg class="h-3.5 w-3.5 shrink-0 text-cyan-400/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
          Expert system architecture
        </span>
        <span class="hidden sm:inline text-zinc-600" aria-hidden="true">•</span>
        <span class="inline-flex items-center gap-1.5" role="listitem">
          <svg class="h-3.5 w-3.5 shrink-0 text-cyan-400/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
          Bulletproof integrations
        </span>
      </span>
    </p>

    <div
      class="animate-fade-in-up mt-10 flex w-full flex-col items-center gap-4 sm:w-auto sm:flex-row sm:gap-4"
      style="animation-delay: 0.35s"
    >
      <a
        href={upworkHref}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex h-12 w-full items-center justify-center gap-2.5 rounded-xl bg-cyan-400 px-8 text-sm font-semibold text-zinc-950 transition-all duration-200 hover:bg-cyan-300 active:scale-[0.97] sm:w-auto"
      >
        <svg
          class="h-4 w-4 transition-transform duration-200 group-hover:-translate-y-0.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 0 0 .75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 0 0-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0 1 12 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 0 1-.673-.38m0 0A2.18 2.18 0 0 1 3 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 0 1 3.413-.387m7.5 0V5.25A2.25 2.25 0 0 0 13.5 3h-3a2.25 2.25 0 0 0-2.25 2.25v.894m7.5 0a48.667 48.667 0 0 0-7.5 0M12 12.75h.008v.008H12v-.008Z"
          />
        </svg>
        Hire us on Upwork
      </a>
      <a
        href={workAnchor}
        class="inline-flex h-12 w-full items-center justify-center gap-2 rounded-xl border border-zinc-800 px-8 text-sm font-semibold text-zinc-300 transition-all duration-200 hover:border-zinc-700 hover:bg-zinc-900 active:scale-[0.97] sm:w-auto"
      >
        See our work
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>

    <div
      class="animate-fade-in-up mx-auto mt-16 flex w-full max-w-2xl flex-col items-center gap-6 border-t border-zinc-800/40 pt-8 sm:mt-20 sm:pt-10"
      style="animation-delay: 0.5s"
    >
      <p class="text-xs font-medium uppercase tracking-[0.15em] text-zinc-600">
        Trusted by product teams at
      </p>
      <div
        class="flex w-full flex-wrap items-center justify-center gap-x-10 gap-y-3 text-sm font-medium text-zinc-600"
      >
        <span class="text-zinc-500 transition-colors hover:text-zinc-300">GrowthOS</span>
        <span class="text-zinc-500 transition-colors hover:text-zinc-300">Pulse Analytics</span>
        <span class="text-zinc-500 transition-colors hover:text-zinc-300">Rivet Health</span>
        <span class="text-zinc-500 transition-colors hover:text-zinc-300">Streamforge</span>
      </div>
      <div class="flex items-center gap-8 text-xs text-zinc-700">
        <span class="flex items-center gap-1.5">
          <span class="text-zinc-400 font-semibold">15+</span>
          years experience
        </span>
        <span class="h-3 w-px bg-zinc-800" aria-hidden="true" />
        <span class="flex items-center gap-1.5">
          <span class="text-zinc-400 font-semibold">40+</span>
          projects shipped
        </span>
        <span class="h-3 w-px bg-zinc-800" aria-hidden="true" />
        <span class="flex items-center gap-1.5">
          <span class="text-zinc-400 font-semibold">100%</span>
          on-time delivery
        </span>
      </div>
    </div>
  </div>
</section>

<style is:global>
  @keyframes drift {
    0%, 100% { transform: translate(0, 0); }
    33% { transform: translate(3%, -2%); }
    66% { transform: translate(-2%, 3%); }
  }

  @keyframes drift-reverse {
    0%, 100% { transform: translate(0, 0); }
    33% { transform: translate(-3%, 2%); }
    66% { transform: translate(2%, -3%); }
  }

  .animate-drift {
    animation: drift 20s ease-in-out infinite;
    will-change: transform;
  }

  .animate-drift-reverse {
    animation: drift-reverse 25s ease-in-out infinite;
    will-change: transform;
  }
</style>
