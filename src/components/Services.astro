---
export interface ServiceCard {
  icon: string;
  title: string;
  label: string;
  highlights: string[];
}

export interface Props {
  sectionId?: string;
  heading?: string;
  subheading?: string;
  cards?: ServiceCard[];
}

const defaults: ServiceCard[] = [
  {
    icon: "server",
    title: "SaaS Infrastructure",
    label: "Subscription billing & metering",
    highlights: ["Symfony", "Stripe", "MySQL"],
  },
  {
    icon: "plug",
    title: "API Architecture",
    label: "RESTful & webhook contracts",
    highlights: ["API design", "Webhooks"],
  },
  {
    icon: "gauge",
    title: "Performance Engineering",
    label: "SQL & caching optimisation",
    highlights: ["SQL", "Caching"],
  },
  {
    icon: "window",
    title: "Contract-Driven Frontends",
    label: "Typed React dashboards",
    highlights: ["React", "TypeScript"],
  },
];

const { sectionId = "services", heading = "Capabilities", subheading = "What I do day to day.", cards = defaults } = Astro.props;
---

<section
  id={sectionId}
  class="section-container section-padding relative py-28 sm:py-36 lg:py-44"
  data-reveal
>
  <div class="mx-auto max-w-6xl">
    <div class="mb-4 flex items-center gap-3">
      <span class="h-px w-8 bg-cyan-400/60" aria-hidden="true" />
      <span class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-400">
        {heading}
      </span>
    </div>

    <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <h2 class="heading-lg text-balance text-zinc-100">
        System
        <br />
        <span class="gradient-text">capabilities.</span>
      </h2>
      <p class="max-w-md text-base leading-relaxed text-zinc-300 sm:text-right">
        {subheading}
      </p>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" data-reveal-stagger>
      {
        cards.map((card, i) => (
          <article
            class="group relative cursor-pointer rounded-2xl border border-zinc-800/40 bg-zinc-900/30 p-5 transition-all duration-300 hover:-translate-y-0.5 hover:border-zinc-700/50 hover:bg-zinc-900/60 hover:shadow-[0_0_32px_rgba(34,211,238,0.04)] active:brightness-90"
            data-reveal
            data-si={i}
          >
            <div
              class="mb-4 flex h-9 w-9 items-center justify-center rounded-lg bg-cyan-400/10 transition-colors duration-300 group-hover:bg-cyan-400/15"
            >
              {
                card.icon === "server" && (
                  <svg class="h-4 w-4 text-cyan-400/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 17.25v-.228a4.5 4.5 0 0 0-.12-1.03l-2.268-9.64a3.375 3.375 0 0 0-3.285-2.602H7.923a3.375 3.375 0 0 0-3.285 2.602l-2.268 9.64a4.5 4.5 0 0 0-.12 1.03v.228m19.5 0a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3m19.5 0a3 3 0 0 0-3-3H5.25a3 3 0 0 0-3 3m16.5 0h.008v.008h-.008v-.008Zm-3 0h.008v.008h-.008v-.008Z" />
                  </svg>
                )
              }
              {
                card.icon === "window" && (
                  <svg class="h-4 w-4 text-cyan-400/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25" />
                  </svg>
                )
              }
              {
                card.icon === "plug" && (
                  <svg class="h-4 w-4 text-cyan-400/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z" />
                  </svg>
                )
              }
              {
                card.icon === "gauge" && (
                  <svg class="h-4 w-4 text-cyan-400/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
                  </svg>
                )
              }
            </div>

            <h3 class="heading text-zinc-100">
              {card.title}
            </h3>

            <span class="mt-1 block text-sm leading-relaxed text-zinc-300">
              {card.label}
            </span>

            <ul class="mt-4 flex flex-wrap gap-x-2.5 gap-y-1">
              {
                card.highlights.map((tag) => (
                  <li class="text-xs font-medium tracking-wide text-zinc-300 transition-colors duration-200 group-hover:text-zinc-200">
                    {tag}
                  </li>
                ))
              }
            </ul>
            <span class="mt-3 inline-flex items-center gap-1 text-xs text-zinc-300 transition-all duration-200 group-hover:text-zinc-200">
              Click for details <span aria-hidden="true" class="transition-transform duration-200 group-hover:translate-x-0.5">&rarr;</span>
            </span>
          </article>
        ))
      }
    </div>
  </div>
</section>

<!-- Service modal -->
<div
  id="service-modal"
  class="fixed inset-0 z-[100] flex items-end sm:items-center justify-center p-0 sm:p-4 opacity-0 pointer-events-none transition-opacity duration-300"
  role="dialog"
  aria-modal="true"
  aria-labelledby="service-modal-title"
>
  <div class="absolute inset-0 bg-zinc-950/80 backdrop-blur-sm" data-service-close></div>
  <div class="relative w-full max-w-2xl max-h-screen sm:max-h-[85vh] overflow-y-auto rounded-t-2xl sm:rounded-2xl border-0 sm:border sm:border-zinc-800 bg-zinc-900 shadow-2xl scrollbar-thin">
    <button
      class="sticky top-0 z-10 flex w-full items-center justify-between border-b border-zinc-700/50 bg-zinc-800/95 px-4 py-3 sm:absolute sm:right-3 sm:top-3 sm:w-auto sm:rounded-xl sm:border-0 sm:bg-zinc-700/70 sm:px-3 sm:py-2.5 sm:text-sm sm:font-semibold sm:text-zinc-200 sm:backdrop-blur-sm sm:transition-colors sm:hover:bg-zinc-600/80 sm:hover:text-zinc-100"
      data-service-close
      aria-label="Close"
    >
      <span class="text-sm font-semibold">Close</span>
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
    <div class="p-6 sm:p-10" id="service-modal-body"></div>
  </div>
</div>

<script>
  (() => {
    const modal = document.getElementById("service-modal");
    const body = document.getElementById("service-modal-body");
    const triggers = document.querySelectorAll("[data-si]");
    const closes = modal.querySelectorAll("[data-service-close]");

    const services = [
      {
        title: "SaaS Infrastructure",
        summary: "I build subscription engines that handle metered billing, dunning, multi-tenant isolation, and Stripe reconciliation. No structural rewrites needed as you grow — it's designed to scale from day one.",
        capabilities: [
          "Metered and tiered billing with usage tracking",
          "Subscription lifecycle management — trials, upgrades, downgrades, cancellations",
          "Idempotent Stripe webhook consumers that eliminate duplicate charges",
          "Multi-tenant data isolation at the database level",
          "RESTful APIs expose subscription state, customer data, and invoice history for frontend or third-party consumption",
        ],
        constraints: "Idempotency requires careful consumer design. Multi-tenant isolation adds per-query overhead. Dunning timing must handle multiple time zones and billing cycles.",
        tags: ["Symfony", "Stripe", "MySQL"],
      },
      {
        title: "API Architecture",
        summary: "I design versioned REST APIs where every integration is a first-class contract. Webhooks with signature verification, content negotiation, and backward-compatible evolution — integrators upgrade on their timeline, not mine.",
        capabilities: [
          "Versioned contract-first API design with OpenAPI specs generated from definitions",
          "Webhook dispatch with signature verification and retry logic",
          "Content negotiation (JSON, XML, CSV) per endpoint",
          "Third-party API integration with rate limiting and circuit breakers",
          "Integration tests that validate contract compliance before deployment",
        ],
        constraints: "Backward compatibility requires disciplined versioning. Webhook reliability depends on consumer idempotency. Rate limiting must balance protection with legitimate throughput.",
        tags: ["API design", "Webhooks"],
      },
      {
        title: "Performance Engineering",
        summary: "SQL profiling, multi-layer caching with explicit invalidation, and measurable legacy modernisation. Every optimisation is benchmarked — I don't guess, I measure.",
        capabilities: [
          "SQL query profiling and index optimisation under production load",
          "Multi-layer caching (application, query, HTTP) with TTL and event-driven invalidation",
          "Legacy codebase modernisation with measurable performance gates",
          "Load testing and bottleneck identification",
          "Performance benchmarks integrated into CI/CD to prevent regressions",
        ],
        constraints: "Caching invalidation is the hardest problem — requires disciplined key management. Legacy modernisation often reveals hidden dependencies. Improvements must be validated under production-like load patterns.",
        tags: ["SQL", "Caching"],
      },
      {
        title: "Contract-Driven Frontends",
        summary: "TypeScript interfaces generated from the same API contracts my backend serves. When the API changes, TypeScript catches it at compile time — admin panels, portals, and dashboards stay in sync automatically.",
        capabilities: [
          "TypeScript client generation from OpenAPI contracts",
          "Admin panels with server-side auth and role-based access",
          "Customer-facing portals using the same API contracts",
          "Dashboard visualisation with real-time data integration",
          "Auth flows integrated with the same session management as the backend",
        ],
        constraints: "Contract alignment requires disciplined API governance. TypeScript generation must handle nullable fields and versioned endpoints gracefully. Server-side auth adds complexity to SPA routing.",
        tags: ["React", "TypeScript"],
      },
    ];

    function open(index) {
      const s = services[index];
      body.innerHTML =
        '<h3 class="heading text-zinc-100" id="service-modal-title">' +
        s.title +
        "</h3>" +
        '<p class="mt-4 text-base leading-relaxed text-zinc-300">' +
        s.summary +
        "</p>" +
        '<h4 class="mt-6 text-sm font-semibold text-zinc-200">What it does</h4>' +
        '<ul class="mt-3 space-y-2">' +
        s.capabilities
          .map(
            (c) =>
              '<li class="flex gap-3 text-base text-zinc-300"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-cyan-400/60"></span>' +
              c +
              "</li>"
          )
          .join("") +
        "</ul>" +
        '<h4 class="mt-6 text-sm font-semibold text-zinc-200">Key challenges</h4>' +
        '<p class="mt-2 text-base leading-relaxed text-zinc-300">' +
        s.constraints +
        "</p>" +
        '<div class="mt-6 flex flex-wrap gap-2">' +
        s.tags
          .map(
            (t) =>
              '<span class="rounded-md border border-zinc-700/60 bg-zinc-800/80 px-2 py-0.5 text-sm font-medium text-zinc-200">' +
              t +
              "</span>"
          )
          .join("") +
        "</div>";
      modal.classList.remove("opacity-0", "pointer-events-none");
      document.body.style.overflow = "hidden";
    }

    function close() {
      modal.classList.add("opacity-0", "pointer-events-none");
      document.body.style.overflow = "";
    }

    triggers.forEach((el) => {
      el.addEventListener("click", () => open(parseInt(el.dataset.si)));
    });
    closes.forEach((el) => el.addEventListener("click", close));
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });
  })();
</script>
