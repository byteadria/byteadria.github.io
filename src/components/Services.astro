---
export interface ServiceCard {
  icon: string;
  title: string;
  description: string;
  highlights: string[];
}

export interface Props {
  sectionId?: string;
  heading?: string;
  subheading?: string;
  cards?: ServiceCard[];
}

const defaults: ServiceCard[] = [
  {
    icon: "server",
    title: "SaaS Backend Systems",
    description:
      "Multi-tenant subscription engines with recurring billing, metered usage, and payment lifecycle management. Stripe webhooks reconciled through idempotent consumers; automated dunning, invoicing, and account state machine.",
    highlights: ["Symfony", "Laravel", "Stripe", "MySQL"],
  },
  {
    icon: "plug",
    title: "API Architecture & Integration",
    description:
      "Versioned REST APIs with idempotent endpoints, retry-with-backoff, and signed webhook verification. Middleware connecting SaaS platforms to payment gateways, CRMs, and external services through documented contracts.",
    highlights: ["API design", "Stripe", "Webhooks", "Third-party APIs"],
  },
  {
    icon: "gauge",
    title: "Performance & Scaling",
    description:
      "Query optimization under load, caching layers with invalidation strategies, and connection pooling for PHP backends. Legacy codebase refactoring with minimized operational risk.",
    highlights: ["SQL optimisation", "Caching", "PHP refactoring", "Legacy modernisation"],
  },
  {
    icon: "window",
    title: "Product Interfaces",
    description:
      "React and TypeScript interfaces consuming backend APIs — admin panels, customer portals, and data dashboards authenticated and connected to PHP services.",
    highlights: ["React", "TypeScript"],
  },
];

const { sectionId = "services", heading = "Services", subheading = "Architecture design through to deployment. We own the full delivery loop.", cards = defaults } = Astro.props;
---

<section
  id={sectionId}
  class="section-container section-padding relative py-24 sm:py-32 lg:py-40"
  data-reveal
>
  <!-- Section header -->
  <div class="mx-auto max-w-6xl">
    <div class="mb-4 flex items-center gap-3">
      <span class="h-px w-8 bg-cyan-400/60" aria-hidden="true" />
      <span class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-400">
        {heading}
      </span>
    </div>

    <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <h2 class="heading-lg text-balance text-zinc-100">
        What
        <br />
        <span class="gradient-text">we build.</span>
      </h2>
      <p class="max-w-md text-sm leading-relaxed text-zinc-500 sm:text-right">
        {subheading}
      </p>
    </div>

    <!-- Card grid -->
    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4" data-reveal-stagger>
      {
        cards.map((card) => (
          <article
            class="group relative rounded-2xl border border-zinc-800/50 bg-zinc-900/40 p-6 hover:border-cyan-400/20 hover:bg-zinc-900/80 hover:shadow-[0_0_32px_rgba(34,211,238,0.06)] active:brightness-90 sm:p-7"
            data-tilt
            data-reveal
          >
            <!-- Icon -->
            <div
              class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl bg-cyan-400/10 transition-colors duration-300 group-hover:bg-cyan-400/15"
            >
              {
                card.icon === "server" && (
                  <svg class="h-5 w-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 17.25v-.228a4.5 4.5 0 0 0-.12-1.03l-2.268-9.64a3.375 3.375 0 0 0-3.285-2.602H7.923a3.375 3.375 0 0 0-3.285 2.602l-2.268 9.64a4.5 4.5 0 0 0-.12 1.03v.228m19.5 0a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3m19.5 0a3 3 0 0 0-3-3H5.25a3 3 0 0 0-3 3m16.5 0h.008v.008h-.008v-.008Zm-3 0h.008v.008h-.008v-.008Z" />
                  </svg>
                )
              }
              {
                card.icon === "window" && (
                  <svg class="h-5 w-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25" />
                  </svg>
                )
              }
              {
                card.icon === "plug" && (
                  <svg class="h-5 w-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z" />
                  </svg>
                )
              }
              {
                card.icon === "gauge" && (
                  <svg class="h-5 w-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
                  </svg>
                )
              }
            </div>

            <!-- Card content -->
            <h3 class="heading text-zinc-100">
              {card.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-zinc-400">
              {card.description}
            </p>

            <!-- Technology highlights -->
            <ul class="mt-5 flex flex-wrap gap-1.5">
              {
                card.highlights.map((tag) => (
                  <li class="rounded-md border border-zinc-800/60 bg-zinc-900/80 px-2 py-0.5 text-xs font-medium text-zinc-500 transition-colors duration-200 group-hover:border-zinc-700/60 group-hover:text-zinc-400">
                    {tag}
                  </li>
                ))
              }
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
