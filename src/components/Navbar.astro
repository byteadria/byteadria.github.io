---
import NavItem from "./NavItem.astro";
---

<nav class="fixed left-0 right-0 top-0 z-50 border-b border-zinc-800/50 bg-zinc-950/80 backdrop-blur-xl" aria-label="Main navigation">
  <div class="section-container flex h-16 items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-2 text-lg font-semibold tracking-tight text-zinc-100" aria-label="GitByte DOO home">
      <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-cyan-400/10 text-sm font-bold text-cyan-400" aria-hidden="true">
        G
      </span>
      <span>GitByte DOO</span>
    </a>

    <div class="hidden items-center gap-6 text-sm font-medium text-zinc-400 lg:flex" role="list">
      <NavItem href="#work" label="Work" />
      <NavItem href="#services" label="Services" />
      <NavItem href="#stack" label="Stack" />
      <NavItem href="#about" label="About" />
      <NavItem href="#contact" label="Contact" />
    </div>

    <div class="flex items-center gap-3">
      <a
        href="https://www.upwork.com/agencies/1942512521968274328/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-xl bg-cyan-400 px-4 py-2 text-sm font-semibold text-zinc-950 transition-colors duration-200 hover:bg-cyan-300 active:scale-[0.97]"
