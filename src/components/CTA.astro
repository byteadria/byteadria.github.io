---
export interface Props {
  sectionId?: string;
  upworkHref?: string;
  email?: string;
}

const {
  sectionId = "contact",
  upworkHref = "https://upwork.com",
  email = "hello@forgesystems.dev",
} = Astro.props;
---

<section
  id={sectionId}
  class="section-container section-padding relative py-24 sm:py-32 lg:py-40"
  data-reveal
>
  <div class="mx-auto max-w-6xl">
    <!-- Section label -->
    <div class="mb-4 flex items-center gap-3">
      <span class="h-px w-8 bg-cyan-400/60" aria-hidden="true" />
      <span class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-400">
        Let's talk
      </span>
    </div>

    <div class="grid gap-16 lg:grid-cols-5">
      <!-- Left: headline + text -->
      <div class="lg:col-span-2">
        <h2 class="text-balance text-3xl font-bold tracking-tight text-zinc-100 sm:text-4xl lg:text-5xl">
          Ready to build
          <br />
          something
          <span class="gradient-text">exceptional?</span>
        </h2>
        <p class="mt-4 max-w-md text-sm leading-relaxed text-zinc-400">
          We're selectively taking on new projects. Tell us what you're
          building and we'll get back to you within 24 hours — often sooner.
        </p>

        <!-- Contact info -->
        <div class="mt-8 space-y-4">
          <a
            href={upworkHref}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex h-12 w-full items-center justify-center gap-2.5 rounded-xl bg-cyan-400 px-6 text-sm font-semibold text-zinc-950 transition-all duration-200 hover:bg-cyan-300 active:scale-[0.97] sm:w-auto"
          >
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:-translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 0 0 .75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 0 0-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0 1 12 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 0 1-.673-.38m0 0A2.18 2.18 0 0 1 3 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 0 1 3.413-.387m7.5 0V5.25A2.25 2.25 0 0 0 13.5 3h-3a2.25 2.25 0 0 0-2.25 2.25v.894m7.5 0a48.667 48.667 0 0 0-7.5 0M12 12.75h.008v.008H12v-.008Z" />
            </svg>
            Hire on Upwork
          </a>
          <a
            href={`mailto:${email}`}
            class="inline-flex h-12 items-center justify-center gap-2 rounded-xl border border-zinc-800 px-6 text-sm font-semibold text-zinc-300 transition-all duration-200 hover:border-zinc-700 hover:bg-zinc-900 active:scale-[0.97] sm:w-auto"
          >
            <svg class="h-4 w-4 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            {email}
          </a>
        </div>

        <!-- Trust line -->
        <p class="mt-6 text-xs text-zinc-600">
          <span class="text-cyan-400/70">&#10003;</span> No commitment needed.
          We'll discuss scope, timeline, and fit before anything.
        </p>
      </div>

      <!-- Right: contact form -->
      <div class="glass rounded-2xl p-6 sm:p-8 lg:col-span-3">
        <form
          action={`mailto:${email}`}
          method="GET"
          enctype="text/plain"
          class="space-y-5"
        >
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="name" class="mb-1.5 block text-xs font-medium text-zinc-500">
                Name
              </label>
              <input
                id="name"
                name="name"
                type="text"
                required
                placeholder="Your name"
                class="w-full rounded-xl border border-zinc-800/60 bg-zinc-900/50 px-4 py-2.5 text-sm text-zinc-200 placeholder-zinc-600 transition-colors duration-200 focus:border-cyan-400/40 focus:bg-zinc-900/80 focus:outline-none"
              />
            </div>
            <div>
              <label for="email-input" class="mb-1.5 block text-xs font-medium text-zinc-500">
                Email
              </label>
              <input
                id="email-input"
                name="email"
                type="email"
                required
                placeholder="you@company.com"
                class="w-full rounded-xl border border-zinc-800/60 bg-zinc-900/50 px-4 py-2.5 text-sm text-zinc-200 placeholder-zinc-600 transition-colors duration-200 focus:border-cyan-400/40 focus:bg-zinc-900/80 focus:outline-none"
              />
            </div>
          </div>
          <div>
            <label for="message" class="mb-1.5 block text-xs font-medium text-zinc-500">
              Message
            </label>
            <textarea
              id="message"
              name="body"
              rows={4}
              required
              placeholder="Tell us about your project — tech stack, timeline, team size, and what you're trying to achieve."
              class="w-full resize-none rounded-xl border border-zinc-800/60 bg-zinc-900/50 px-4 py-2.5 text-sm text-zinc-200 placeholder-zinc-600 transition-colors duration-200 focus:border-cyan-400/40 focus:bg-zinc-900/80 focus:outline-none"
            ></textarea>
          </div>
          <div class="flex items-center justify-between gap-4">
            <p class="text-xs text-zinc-600">
              Or email us directly at
              <a href={`mailto:${email}`} class="text-cyan-400/80 underline-offset-2 hover:underline">
                {email}
              </a>
            </p>
            <button
              type="submit"
              class="inline-flex h-10 shrink-0 items-center justify-center gap-2 rounded-xl bg-cyan-400 px-6 text-sm font-semibold text-zinc-950 transition-all duration-200 hover:bg-cyan-300 active:scale-[0.97]"
            >
              Send message
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
              </svg>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
