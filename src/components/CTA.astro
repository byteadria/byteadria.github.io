---
export interface Props {
  sectionId?: string;
  upworkHref?: string;
  email?: string;
  web3formsKey?: string;
}

const {
  sectionId = "contact",
  upworkHref = "https://upwork.com/freelancers/~016c054e2db68a3319?mp_source=share",
  email = "hello.gitbyte@gmail.com",
  web3formsKey = "03e1d391-8c07-4f26-a31c-d0ac631fe7ad",
} = Astro.props;
---

<section
  id={sectionId}
  class="section-container section-padding relative py-24 sm:py-32 lg:py-40 bg-gradient-section"
  data-reveal
>
  <div class="mx-auto max-w-6xl">
    <!-- Section label -->
    <div class="section-label">
      <span class="section-label-line" aria-hidden="true" />
      <span class="section-label-text">Contact</span>
    </div>

    <div class="grid gap-16 lg:grid-cols-5">
      <!-- Left: headline + text -->
      <div class="lg:col-span-2">
        <h2 class="heading-lg text-balance text-zinc-100">
          Start a
          <br />
          <span class="gradient-text">conversation.</span>
        </h2>
        <p class="mt-4 max-w-md text-sm leading-relaxed text-zinc-400">
          Describe the system you're building. If it fits our practice, we'll
          respond with a technical assessment within two days.
        </p>

        <!-- Quick contact strip -->
        <div class="mt-6 flex flex-wrap gap-2">
          <a
            href={`mailto:${email}`}
            class="inline-flex items-center gap-1.5 rounded-lg border border-zinc-800/60 bg-zinc-900/30 px-3 py-1.5 text-xs text-zinc-500 transition-colors hover:border-zinc-700 hover:text-zinc-300"
          >
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            {email}
          </a>
          <span class="inline-flex items-center gap-1.5 rounded-lg border border-zinc-800/60 bg-zinc-900/30 px-3 py-1.5 text-xs text-zinc-500">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
            Podgorica, Montenegro
          </span>
        </div>

        <!-- Primary CTA -->
        <div class="mt-8 space-y-3">
          <a
            href={upworkHref}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex h-13 w-full items-center justify-center gap-2.5 rounded-xl bg-cyan-400 px-6 text-sm font-semibold text-zinc-950 transition-colors duration-200 hover:bg-cyan-300 active:scale-[0.97] sm:w-auto"
            style="min-height: 3.25rem"
          >
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:-translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 0 0 .75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 0 0-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0 1 12 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 0 1-.673-.38m0 0A2.18 2.18 0 0 1 3 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 0 1 3.413-.387m7.5 0V5.25A2.25 2.25 0 0 0 13.5 3h-3a2.25 2.25 0 0 0-2.25 2.25v.894m7.5 0a48.667 48.667 0 0 0-7.5 0M12 12.75h.008v.008H12v-.008Z" />
            </svg>
            Start a project
          </a>
        </div>

        <p class="mt-4 text-xs text-zinc-600">
          <span class="text-cyan-400/70">&#10003;</span> Technical assessment
          before commitment.
        </p>
      </div>

      <!-- Right: contact form -->
      <div class="glass rounded-2xl p-6 sm:p-8 lg:col-span-3">
        <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-5">
          <input type="hidden" name="access_key" value={web3formsKey} />
          <input type="hidden" name="subject" value="GitByte DOO &ndash; New SaaS inquiry" />
          <input type="hidden" name="redirect" value="" />
          <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="name" class="mb-1.5 block text-xs font-medium text-zinc-500">
                Name
              </label>
              <input
                id="name"
                name="name"
                type="text"
                required
                placeholder="Your name"
                class="w-full rounded-xl border border-zinc-800/60 bg-zinc-900/50 px-4 py-2.5 text-sm text-zinc-200 placeholder-zinc-600 transition-colors duration-200 focus:border-cyan-400/40 focus:bg-zinc-900/80 focus:outline-none"
              />
            </div>
            <div>
              <label for="email-input" class="mb-1.5 block text-xs font-medium text-zinc-500">
                Email
              </label>
              <input
                id="email-input"
                name="email"
                type="email"
                required
                placeholder="you@company.com"
                class="w-full rounded-xl border border-zinc-800/60 bg-zinc-900/50 px-4 py-2.5 text-sm text-zinc-200 placeholder-zinc-600 transition-colors duration-200 focus:border-cyan-400/40 focus:bg-zinc-900/80 focus:outline-none"
              />
            </div>
          </div>
          <div>
            <label for="message" class="mb-1.5 block text-xs font-medium text-zinc-500">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows={4}
              required
              placeholder="Tech stack, timeline, and what you're trying to achieve."
              class="w-full resize-none rounded-xl border border-zinc-800/60 bg-zinc-900/50 px-4 py-2.5 text-sm text-zinc-200 placeholder-zinc-600 transition-colors duration-200 focus:border-cyan-400/40 focus:bg-zinc-900/80 focus:outline-none"
            ></textarea>
          </div>
          <div id="form-status" class="hidden text-sm"></div>
          <div class="flex items-center justify-between gap-4">
            <p class="text-xs text-zinc-600">
              Or email us directly at
              <a href={`mailto:${email}`} class="text-cyan-400/80 underline-offset-2 hover:underline">
                {email}
              </a>
            </p>
            <button
              id="form-submit"
              type="submit"
              class="inline-flex h-10 shrink-0 items-center justify-center gap-2 rounded-xl bg-cyan-400 px-6 text-sm font-semibold text-zinc-950 transition-colors duration-200 hover:bg-cyan-300 active:scale-[0.97]"
            >
              <span id="form-submit-text">Send message</span>
              <span id="form-spinner" class="hidden">
                <svg class="h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
                </svg>
              </span>
              <svg id="form-send-icon" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
              </svg>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const form = document.getElementById("contact-form");
    if (!form) return;

    const status = document.getElementById("form-status");
    const submitBtn = document.getElementById("form-submit");
    const submitText = document.getElementById("form-submit-text");
    const spinner = document.getElementById("form-spinner");
    const sendIcon = document.getElementById("form-send-icon");

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      status.classList.add("hidden");
      status.classList.remove("text-green-400", "text-red-400");
      submitBtn.disabled = true;
      submitText.textContent = "Sending...";
      spinner.classList.remove("hidden");
      sendIcon.classList.add("hidden");

      try {
        const res = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(Object.fromEntries(new FormData(form))),
        });

        const data = await res.json();

        if (data.success) {
          status.textContent = "Message sent. We'll get back within 48 hours.";
          status.className = "text-sm text-green-400";
          form.reset();
        } else {
          status.textContent = data.message || "Something went wrong. Please try again.";
          status.className = "text-sm text-red-400";
        }
      } catch {
        status.textContent = "Network error. Please try again or email us directly.";
        status.className = "text-sm text-red-400";
      }

      status.classList.remove("hidden");
      submitBtn.disabled = false;
      submitText.textContent = "Send message";
      spinner.classList.add("hidden");
      sendIcon.classList.remove("hidden");
    });
  })();
</script>
