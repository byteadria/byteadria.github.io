---
export interface TechItem {
  id: string;
  name: string;
  color: string;
}

export interface Props {
  sectionId?: string;
  heading?: string;
  items?: TechItem[];
}

const defaults: TechItem[] = [
  { id: "php", name: "PHP", color: "#777BB4" },
  { id: "symfony", name: "Symfony", color: "#000000" },
  { id: "laravel", name: "Laravel", color: "#FF2D20" },
  { id: "react", name: "React", color: "#61DAFB" },
  { id: "typescript", name: "TypeScript", color: "#3178C6" },
  { id: "mysql", name: "MySQL", color: "#4479A1" },
  { id: "docker", name: "Docker", color: "#2496ED" },
  { id: "stripe", name: "Stripe", color: "#008CDD" },
];

const { sectionId = "stack", heading = "Tech Stack", items = defaults } = Astro.props;
---

<section
  id={sectionId}
  class="section-container section-padding relative py-24 sm:py-32 lg:py-40"
  data-reveal
>
  <div class="mx-auto max-w-6xl">
    <div class="mb-4 flex items-center gap-3">
      <span class="h-px w-8 bg-cyan-400/60" aria-hidden="true" />
      <span class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-400">
        {heading}
      </span>
    </div>

    <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <h2 class="heading-lg text-balance text-zinc-100">
        Our
        <br />
        <span class="gradient-text">tech stack.</span>
      </h2>
      <p class="max-w-md text-sm leading-relaxed text-zinc-500 sm:text-right">
        Tools we use to build production systems.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-2 gap-3 sm:grid-cols-4" data-reveal-stagger>
      {
        items.map((tech) => (
          <div
            class="group relative flex flex-col items-center gap-3 rounded-xl border border-zinc-800/40 bg-zinc-900/30 px-2 py-5 hover:border-zinc-700/60 hover:bg-zinc-900/70 hover:shadow-[0_0_24px_rgba(34,211,238,0.05)] active:brightness-90 sm:px-3 sm:py-6"
            data-tilt
            data-reveal
          >
            <!-- Icon -->
            <div class="flex h-10 w-10 items-center justify-center sm:h-12 sm:w-12">
              {
                tech.id === "php" && (
                  <svg viewBox="0 0 24 24" class="h-7 w-7 sm:h-8 sm:w-8" fill="none">
                    <circle cx="12" cy="12" r="9" stroke={tech.color} stroke-width="1.2" opacity="0.4" />
                    <text x="12" y="15" text-anchor="middle" font-size="8" font-weight="700" fill={tech.color} font-family="Inter, system-ui, sans-serif">PHP</text>
                  </svg>
                )
              }
              {
                tech.id === "symfony" && (
                  <svg viewBox="0 0 24 24" class="h-7 w-7 sm:h-8 sm:w-8" fill="none">
                    <circle cx="12" cy="12" r="9" stroke={tech.color} stroke-width="1.2" opacity="0.4" />
                    <text x="12" y="15" text-anchor="middle" font-size="6" font-weight="700" fill="#fff" font-family="Inter, system-ui, sans-serif">SF</text>
                  </svg>
                )
              }
              {
                tech.id === "react" && (
                  <svg viewBox="0 0 24 24" class="h-7 w-7 sm:h-8 sm:w-8" fill="none" stroke={tech.color} stroke-width="1.2">
                    <circle cx="12" cy="12" r="2.2" />
                    <ellipse cx="12" cy="12" rx="7.5" ry="2.8" transform="rotate(0 12 12)" />
                    <ellipse cx="12" cy="12" rx="7.5" ry="2.8" transform="rotate(60 12 12)" />
                    <ellipse cx="12" cy="12" rx="7.5" ry="2.8" transform="rotate(120 12 12)" />
                  </svg>
                )
              }
              {
                tech.id === "typescript" && (
                  <svg viewBox="0 0 24 24" class="h-7 w-7 sm:h-8 sm:w-8" fill="none">
                    <rect x="3" y="3" width="18" height="18" rx="3" stroke={tech.color} stroke-width="1.2" opacity="0.4" />
                    <text x="12" y="15" text-anchor="middle" font-size="7" font-weight="700" fill={tech.color} font-family="Inter, system-ui, sans-serif">TS</text>
                  </svg>
                )
              }
              {
                tech.id === "mysql" && (
                  <svg viewBox="0 0 24 24" class="h-7 w-7 sm:h-8 sm:w-8" fill="none" stroke={tech.color} stroke-width="1.3">
                    <ellipse cx="12" cy="10" rx="7" ry="3" />
                    <path d="M5 10v4c0 1.657 3.134 3 7 3s7-1.343 7-3v-4" />
                    <path d="M5 14v4c0 1.657 3.134 3 7 3s7-1.343 7-3v-4" />
                  </svg>
                )
              }
              {
                tech.id === "docker" && (
                  <svg viewBox="0 0 24 24" class="h-7 w-7 sm:h-8 sm:w-8" fill="none" stroke={tech.color} stroke-width="1.3">
                    <rect x="3" y="11" width="4" height="4" rx="0.5" opacity="0.7" />
                    <rect x="8" y="11" width="4" height="4" rx="0.5" opacity="0.7" />
                    <rect x="13" y="11" width="4" height="4" rx="0.5" opacity="0.7" />
                    <rect x="8" y="6" width="4" height="4" rx="0.5" opacity="0.7" />
                    <rect x="13" y="6" width="4" height="4" rx="0.5" opacity="0.7" />
                    <path d="M3 15v2.5a.5.5 0 0 0 .5.5h17a.5.5 0 0 0 .5-.5V15" />
                    <path d="M19 10c0-1.5-2-2.5-3-3" opacity="0.5" />
                  </svg>
                )
              }
              {
                tech.id === "laravel" && (
                  <svg viewBox="0 0 24 24" class="h-7 w-7 sm:h-8 sm:w-8" fill="none" stroke={tech.color} stroke-width="1.2">
                    <path d="M5 4L12 8L19 4" />
                    <path d="M5 4V12L12 16" />
                    <path d="M5 12L12 16" />
                    <path d="M12 8V16" />
                    <path d="M12 16L19 12" />
                    <path d="M19 4V12" />
                  </svg>
                )
              }
              {
                tech.id === "stripe" && (
                  <svg viewBox="0 0 24 24" class="h-7 w-7 sm:h-8 sm:w-8" fill="none">
                    <rect x="3" y="3" width="18" height="18" rx="3" stroke={tech.color} stroke-width="1.2" opacity="0.4" />
                    <text x="12" y="15" text-anchor="middle" font-size="7" font-weight="700" fill={tech.color} font-family="Inter, system-ui, sans-serif">S</text>
                  </svg>
                )
              }
            </div>

            <!-- Label -->
            <span class="text-xs font-medium text-zinc-500 transition-colors duration-200 group-hover:text-zinc-300">
              {tech.name}
            </span>

            <!-- Hover brand-color dot -->
            <span
              class="absolute -top-px left-1/2 h-0.5 w-0 -translate-x-1/2 rounded-full transition-[width] duration-300 group-hover:w-8"
              style="background-color: {tech.color}"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>
