---
interface TechItem {
  id: string;
  name: string;
  subtitle: string;
  color: string;
}

export interface Props {
  sectionId?: string;
  heading?: string;
}

const items: TechItem[] = [
  { id: "php", name: "PHP", subtitle: "8.x Runtime", color: "#777BB4" },
  { id: "symfony", name: "Symfony", subtitle: "Framework", color: "#000000" },
  { id: "laravel", name: "Laravel", subtitle: "Ecosystem", color: "#FF2D20" },
  { id: "react", name: "React", subtitle: "UI Layer", color: "#61DAFB" },
  { id: "typescript", name: "TypeScript", subtitle: "Typed Frontend", color: "#3178C6" },
  { id: "mysql", name: "MySQL", subtitle: "Relational DB", color: "#4479A1" },
  { id: "docker", name: "Docker", subtitle: "Infrastructure", color: "#2496ED" },
  { id: "stripe", name: "Stripe", subtitle: "Payment API", color: "#008CDD" },
];

const { sectionId = "stack", heading = "Tech Stack" } = Astro.props;
---

<section
  id={sectionId}
  class="section-container section-padding relative py-28 sm:py-36 lg:py-44"
  data-reveal
>
  <div class="mx-auto max-w-6xl">
    <div class="mb-4 flex items-center gap-3">
      <span class="h-px w-8 bg-cyan-400/60" aria-hidden="true" />
      <span class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-400">
        {heading}
      </span>
    </div>

    <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <h2 class="heading-lg text-balance text-zinc-100">
        Tools I
        <br />
        <span class="gradient-text">use daily.</span>
      </h2>
    </div>

    <div class="mt-12 grid grid-cols-2 gap-5 sm:grid-cols-4 lg:grid-cols-4" data-reveal-stagger>
      {
        items.map((tech) => (
          <div
            class="group relative flex flex-col items-center gap-5 rounded-xl border border-zinc-800/30 bg-zinc-900/30 px-4 py-8 transition-all duration-300 hover:-translate-y-0.5 hover:border-zinc-700/50 hover:bg-zinc-900/60 hover:shadow-[0_0_24px_rgba(34,211,238,0.03)] active:brightness-90 sm:py-10"
            data-reveal
          >
            <div class="flex h-20 w-20 items-center justify-center">
              {
                tech.id === "php" && (
                  <svg viewBox="0 0 24 24" class="h-14 w-14 sm:h-16 sm:w-16" fill="none">
                    <circle cx="12" cy="12" r="9" stroke={tech.color} stroke-width="1.5" opacity="0.35" />
                    <text x="12" y="15" text-anchor="middle" font-size="8" font-weight="700" fill={tech.color} font-family="Inter, system-ui, sans-serif">PHP</text>
                  </svg>
                )
              }
              {
                tech.id === "symfony" && (
                  <svg viewBox="0 0 24 24" class="h-14 w-14 sm:h-16 sm:w-16" fill="none">
                    <circle cx="12" cy="12" r="9" stroke={tech.color} stroke-width="1.5" opacity="0.35" />
                    <text x="12" y="15" text-anchor="middle" font-size="6" font-weight="700" fill="#fff" font-family="Inter, system-ui, sans-serif">SF</text>
                  </svg>
                )
              }
              {
                tech.id === "react" && (
                  <svg viewBox="0 0 24 24" class="h-14 w-14 sm:h-16 sm:w-16" fill="none" stroke={tech.color} stroke-width="1.5">
                    <circle cx="12" cy="12" r="2.5" />
                    <ellipse cx="12" cy="12" rx="8.5" ry="3" transform="rotate(0 12 12)" />
                    <ellipse cx="12" cy="12" rx="8.5" ry="3" transform="rotate(60 12 12)" />
                    <ellipse cx="12" cy="12" rx="8.5" ry="3" transform="rotate(120 12 12)" />
                  </svg>
                )
              }
              {
                tech.id === "typescript" && (
                  <svg viewBox="0 0 24 24" class="h-14 w-14 sm:h-16 sm:w-16" fill="none">
                    <rect x="3" y="3" width="18" height="18" rx="3" stroke={tech.color} stroke-width="1.5" opacity="0.35" />
                    <text x="12" y="15" text-anchor="middle" font-size="7" font-weight="700" fill={tech.color} font-family="Inter, system-ui, sans-serif">TS</text>
                  </svg>
                )
              }
              {
                tech.id === "mysql" && (
                  <svg viewBox="0 0 24 24" class="h-14 w-14 sm:h-16 sm:w-16" fill="none" stroke={tech.color} stroke-width="1.5">
                    <ellipse cx="12" cy="10" rx="7" ry="3" />
                    <path d="M5 10v4c0 1.657 3.134 3 7 3s7-1.343 7-3v-4" />
                    <path d="M5 14v4c0 1.657 3.134 3 7 3s7-1.343 7-3v-4" />
                  </svg>
                )
              }
              {
                tech.id === "docker" && (
                  <svg viewBox="0 0 24 24" class="h-14 w-14 sm:h-16 sm:w-16" fill="none" stroke={tech.color} stroke-width="1.5">
                    <rect x="3" y="11" width="4" height="4" rx="0.5" opacity="0.7" />
                    <rect x="8" y="11" width="4" height="4" rx="0.5" opacity="0.7" />
                    <rect x="13" y="11" width="4" height="4" rx="0.5" opacity="0.7" />
                    <rect x="8" y="6" width="4" height="4" rx="0.5" opacity="0.7" />
                    <rect x="13" y="6" width="4" height="4" rx="0.5" opacity="0.7" />
                    <path d="M3 15v2.5a.5.5 0 0 0 .5.5h17a.5.5 0 0 0 .5-.5V15" />
                    <path d="M19 10c0-1.5-2-2.5-3-3" opacity="0.5" />
                  </svg>
                )
              }
              {
                tech.id === "laravel" && (
                  <svg viewBox="0 0 24 24" class="h-14 w-14 sm:h-16 sm:w-16" fill="none" stroke={tech.color} stroke-width="1.5">
                    <path d="M5 4L12 8L19 4" />
                    <path d="M5 4V12L12 16" />
                    <path d="M5 12L12 16" />
                    <path d="M12 8V16" />
                    <path d="M12 16L19 12" />
                    <path d="M19 4V12" />
                  </svg>
                )
              }
              {
                tech.id === "stripe" && (
                  <svg viewBox="0 0 24 24" class="h-14 w-14 sm:h-16 sm:w-16" fill="none">
                    <rect x="3" y="3" width="18" height="18" rx="3" stroke={tech.color} stroke-width="1.5" opacity="0.35" />
                    <text x="12" y="15" text-anchor="middle" font-size="7" font-weight="700" fill={tech.color} font-family="Inter, system-ui, sans-serif">S</text>
                  </svg>
                )
              }
            </div>
            <div class="flex flex-col items-center gap-0.5">
              <span class="text-sm font-medium text-zinc-300 transition-colors duration-200 group-hover:text-zinc-200">
                {tech.name}
              </span>
              <span class="text-sm text-zinc-300">
                {tech.subtitle}
              </span>
            </div>
            <span
              class="absolute -top-px left-1/2 h-0.5 w-0 -translate-x-1/2 rounded-full transition-[width] duration-300 group-hover:w-10"
              style="background-color: {tech.color}"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>
