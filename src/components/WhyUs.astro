---
export interface WhyItem {
  icon: string;
  title: string;
  description: string;
}

export interface Props {
  sectionId?: string;
  heading?: string;
  items?: WhyItem[];
}

const defaults: WhyItem[] = [
  {
    icon: "users",
    title: "Senior-only team",
    description:
      "Every contributor is a staff-level engineer with 10+ years shipping production systems. No juniors, no delegation chains — just experienced judgment from day one.",
  },
  {
    icon: "lightbulb",
    title: "Product-minded engineers",
    description:
      "We don't just code — we understand your users, your market, and your trade-offs. Expect architectural recommendations that consider business outcomes, not just tech debt.",
  },
  {
    icon: "target",
    title: "End-to-end ownership",
    description:
      "From whiteboard sketches to production monitoring and incident response, we own the full lifecycle. You get one point of contact, one standard of quality, end to end.",
  },
  {
    icon: "shield",
    title: "Upwork Top Rated Plus",
    description:
      "100% job success score with verified expertise and a track record of repeat engagements from funded startups to Fortune 500 teams. Enterprise-grade vetting, no enterprise overhead.",
  },
  {
    icon: "zap",
    title: "No-nonsense process",
    description:
      "Slack-first communication, weekly deliverables, and zero unnecessary meetings. We move fast because we respect your time as much as our own.",
  },
];

const { sectionId = "why-us", heading = "Why Forge Systems", items = defaults } = Astro.props;
---

<section
  id={sectionId}
  class="section-container section-padding relative py-24 sm:py-32 lg:py-40"
  data-reveal
>
  <div class="mx-auto max-w-6xl">
    <div class="mb-4 flex items-center gap-3">
      <span class="h-px w-8 bg-cyan-400/60" aria-hidden="true" />
      <span class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-400">
        {heading}
      </span>
    </div>

    <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <h2 class="text-balance text-3xl font-bold tracking-tight text-zinc-100 sm:text-4xl lg:text-5xl">
        What makes us
        <br />
        <span class="gradient-text">different.</span>
      </h2>
      <p class="max-w-md text-sm leading-relaxed text-zinc-500 sm:text-right">
        Five principles that define how we work — and who we work with.
      </p>
    </div>

    <div class="mt-12 grid gap-px overflow-hidden rounded-2xl border border-zinc-800/40 bg-zinc-800/20 sm:grid-cols-2 lg:grid-cols-3" data-reveal-stagger>
      {
        items.map((item) => (
          <div
            class="flex flex-col gap-4 bg-zinc-950 p-6 transition-colors duration-200 hover:bg-zinc-900/80 sm:p-7 lg:p-8"
            data-tilt
            data-reveal
          >
            <!-- Icon + title row -->
            <div class="flex items-center gap-3">
              <div
                class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-cyan-400/10"
              >
                {
                  item.icon === "users" && (
                    <svg class="h-4 w-4 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                    </svg>
                  )
                }
                {
                  item.icon === "lightbulb" && (
                    <svg class="h-4 w-4 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
                    </svg>
                  )
                }
                {
                  item.icon === "target" && (
                    <svg class="h-4 w-4 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
                    </svg>
                  )
                }
                {
                  item.icon === "shield" && (
                    <svg class="h-4 w-4 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
                    </svg>
                  )
                }
                {
                  item.icon === "zap" && (
                    <svg class="h-4 w-4 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
                    </svg>
                  )
                }
              </div>
              <h3 class="text-sm font-semibold text-zinc-100">
                {item.title}
              </h3>
            </div>

            <!-- Description -->
            <p class="text-sm leading-relaxed text-zinc-500">
              {item.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
